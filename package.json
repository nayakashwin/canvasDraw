  "description": "A browser-based diagramming application with UML, workflow, and freehand drawing capabilities",
  "main": "dist/main.js",
  "scripts": {
    "dev": "webpack serve --mode development --open --config webpack.config.cjs",
    "build": "webpack --mode production --config webpack.config.cjs",
    "start": "node server.js",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "diagramming",
    "canvas",
    "uml",
    "workflow",
    "drawing",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
